{
  "private": true,
  "scripts": {
    "sync-env": "bash scripts/sync-env.sh",
    "predev": "pnpm sync-env",
    "dev": "pnpm -r --parallel dev",
    "prebuild": "pnpm sync-env",
    "build": "pnpm -r build",
    "prelint": "pnpm sync-env",
    "lint": "pnpm -r lint && pnpm check:web-conventions",
    "check:web-conventions": "node scripts/check-web-conventions.mjs",
    "pretest": "pnpm sync-env",
    "test": "pnpm -r test",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:headed": "env -u NO_COLOR playwright test --headed",
    "predb:setup": "pnpm sync-env",
    "db:start": "docker compose up -d --wait postgres",
    "db:stop": "docker compose stop postgres",
    "db:setup": "pnpm db:start && pnpm --filter @todo-list/api db:deploy",
    "db:login": "docker compose exec postgres psql -U postgres",
    "format": "biome check --write .",
    "format:check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "lefthook": "^2.1.6"
  }
}
