{
  "private": true,
  "scripts": {
    "sync-env": "bash scripts/sync-env.sh",
    "predev": "pnpm sync-env",
    "dev": "pnpm -r --parallel dev",
    "prebuild": "pnpm sync-env",
    "build": "pnpm -r build",
    "prelint": "pnpm sync-env",
    "lint": "pnpm -r lint && pnpm check:web-conventions",
    "check:web-conventions": "node scripts/check-web-conventions.mjs",
    "pretest": "pnpm sync-env",
    "test": "pnpm -r test",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:headed": "env -u NO_COLOR playwright test --headed",
    "presupabase:setup": "pnpm sync-env",
    "supabase:start": "pnpm exec supabase start",
    "supabase:stop": "pnpm exec supabase stop",
    "supabase:setup": "pnpm supabase:start && pnpm --filter @todo-list/api db:deploy",
    "db:login": "docker exec -it supabase_db_todo-list psql -U postgres",
    "format": "biome check --write .",
    "format:check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "lefthook": "^2.1.6",
    "supabase": "^2.92.0"
  }
}
