{
  "name": "@todo-list/api",
  "version": "0.1.0",
  "private": true,
  "exports": {
    "./auth": "./src/shared/auth/auth.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "predev": "pnpm --dir ../.. sync-env",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --dir ../.. sync-env",
    "build": "tsc --noEmit",
    "lint": "pnpm lint:code && pnpm lint:deps",
    "lint:code": "oxlint --type-aware --type-check src/",
    "lint:deps": "depcruise --output-type err src",
    "pretest": "pnpm --dir ../.. sync-env",
    "test": "vitest run",
    "predb:generate": "pnpm --dir ../.. sync-env",
    "db:generate": "prisma generate",
    "predb:deploy": "pnpm --dir ../.. sync-env",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "predb:migrate": "pnpm --dir ../.. sync-env",
    "db:migrate": "prisma migrate dev",
    "predb:push": "pnpm --dir ../.. sync-env",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.9",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@todo-list/schema": "workspace:*",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "hono": "^4.12.15",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "dependency-cruiser": "^17.3.10",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
