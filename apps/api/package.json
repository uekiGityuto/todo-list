{
  "name": "@todo-list/api",
  "version": "0.1.0",
  "private": true,
  "exports": {
    "./client": "./src/client.ts"
  },
  "scripts": {
    "predev": "pnpm --dir ../.. sync-env",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --dir ../.. sync-env",
    "build": "tsc --noEmit",
    "lint": "oxlint --type-aware --type-check src/",
    "pretest": "pnpm --dir ../.. sync-env",
    "test": "vitest run",
    "predb:generate": "pnpm --dir ../.. sync-env",
    "db:generate": "prisma generate",
    "predb:deploy": "pnpm --dir ../.. sync-env",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "predb:migrate": "pnpm --dir ../.. sync-env",
    "db:migrate": "prisma migrate dev",
    "predb:push": "pnpm --dir ../.. sync-env",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@todo-list/schema": "workspace:*",
    "hono": "^4.7.0",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "dotenv": "^17.4.2",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
