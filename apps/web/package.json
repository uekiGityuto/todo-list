{
  "name": "@todo-list/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --dir ../.. sync-env",
    "dev": "next dev",
    "predev:clean": "pnpm --dir ../.. sync-env",
    "dev:clean": "rm -rf .next && next dev",
    "prebuild": "pnpm --dir ../.. sync-env",
    "build": "next build",
    "prestart": "pnpm --dir ../.. sync-env",
    "start": "next start",
    "prestorybook": "pnpm --dir ../.. sync-env",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "pnpm --dir ../.. sync-env",
    "build-storybook": "storybook build",
    "msw:init": "msw init public",
    "lint": "oxlint --type-aware --type-check src/",
    "format": "biome check --write src/ --config-path ../../biome.json",
    "format:check": "biome check src/ --config-path ../../biome.json",
    "pretest": "pnpm --dir ../.. sync-env",
    "test": "vitest run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.100.1",
    "@todo-list/api": "workspace:*",
    "@todo-list/schema": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.15",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/nextjs-vite": "10.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.0.2",
    "msw": "2.13.6",
    "msw-storybook-addon": "^2.0.7",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "shadcn": "^4.4.0",
    "storybook": "10.3.5",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
