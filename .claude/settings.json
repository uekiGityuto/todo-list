{
  "permissions": {
    "ask": [
      "Edit(**/.devcontainer/**)",
      "Edit(**/biome.json)",
      "Write(**/biome.json)",
      "Edit(**/.oxlintrc.json)",
      "Write(**/.oxlintrc.json)",
      "Edit(**/lefthook.yml)",
      "Write(**/lefthook.yml)",
      "Edit(**/tsconfig.json)",
      "Write(**/tsconfig.json)",
      "Write(**/package.json)"
    ],
    "allow": ["Bash(ln -s:*)"],
    "deny": [
      "Edit(apps/web/src/shared/ui/shadcn/**)",
      "Write(apps/web/src/shared/ui/shadcn/**)",
      "Edit(apps/api/src/shared/**/utils.ts)",
      "Write(apps/api/src/shared/**/utils.ts)",
      "Edit(apps/api/src/features/**/schema.ts)",
      "Write(apps/api/src/features/**/schema.ts)",
      "Edit(apps/api/src/features/**/handler.ts)",
      "Write(apps/api/src/features/**/handler.ts)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git commit -n:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git push*--no-verify*)",
      "Bash(git push -n:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-format.sh"
          }
        ]
      }
    ]
  }
}
