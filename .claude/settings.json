{
  "permissions": {
    "ask": [
      "Edit(**/.devcontainer/**)",
      "Edit(**/biome.json)",
      "Write(**/biome.json)",
      "Edit(**/.oxlintrc.json)",
      "Write(**/.oxlintrc.json)",
      "Edit(**/lefthook.yml)",
      "Write(**/lefthook.yml)",
      "Edit(**/tsconfig.json)",
      "Write(**/tsconfig.json)",
      "Write(**/package.json)"
    ],
    "deny": [
      "Edit(apps/web/src/shared/ui/shadcn/**)",
      "Write(apps/web/src/shared/ui/shadcn/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-main-git.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-format.sh"
          }
        ]
      }
    ]
  }
}
