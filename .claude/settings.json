{
  "permissions": {
    "ask": [
      "Edit(**/.devcontainer/**)",
      "Edit(~/.claude/**)",
      "Edit(~/.codex/**)",
      "Edit(~/.gemini/**)",
      "Edit(~/.takt/**)",
      "Edit(~/.agents/**)",
      "Edit(biome.json)",
      "Write(biome.json)",
      "Edit(.oxlintrc.json)",
      "Write(.oxlintrc.json)",
      "Edit(lefthook.yml)",
      "Write(lefthook.yml)",
      "Edit(tsconfig.json)",
      "Write(tsconfig.json)",
      "Edit(package.json)",
      "Write(package.json)"
    ],
    "deny": ["Edit(src/shared/ui/shadcn/**)", "Write(src/shared/ui/shadcn/**)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "branch=$(git branch --show-current 2>/dev/null); if [ \"$branch\" = \"main\" ]; then echo 'mainブランチでの編集は禁止です。featureブランチを作成してください。' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-main-git.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-format.sh"
          }
        ]
      }
    ]
  }
}
