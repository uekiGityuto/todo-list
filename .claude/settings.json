{
  "permissions": {
    "ask": [
      "Edit(**/.devcontainer/**)",
      "Edit(**/biome.json)",
      "Write(**/biome.json)",
      "Edit(**/.oxlintrc.json)",
      "Write(**/.oxlintrc.json)",
      "Edit(**/lefthook.yml)",
      "Write(**/lefthook.yml)",
      "Edit(**/tsconfig.json)",
      "Write(**/tsconfig.json)",
      "Write(**/package.json)"
    ],
    "deny": [
      "Edit(apps/web/src/shared/ui/shadcn/**)",
      "Write(apps/web/src/shared/ui/shadcn/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "branch=$(git branch --show-current 2>/dev/null); file_path=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.file_path // empty'); if [ \"$branch\" = \"main\" ] && [ -n \"$file_path\" ] && echo \"$file_path\" | grep -q \"^$CLAUDE_PROJECT_DIR\"; then echo 'mainブランチでのプロジェクト内ファイル編集は禁止です。featureブランチを作成してください。' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-main-git.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-format.sh"
          }
        ]
      }
    ]
  }
}
